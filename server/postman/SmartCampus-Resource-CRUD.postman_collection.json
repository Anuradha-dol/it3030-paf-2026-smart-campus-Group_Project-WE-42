{
  "info": {
    "_postman_id": "e7cb95b7-88f4-4a90-a63c-7b5ba03f7f5f",
    "name": "SmartCampus Resource CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "CRUD test collection for Resource API"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8085"
    },
    {
      "key": "resourceId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Create Resource",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Lab A\",\n  \"type\": \"LAB\",\n  \"capacity\": 40,\n  \"location\": \"Building B - Floor 2\",\n  \"availableFrom\": \"08:00\",\n  \"availableTo\": \"18:00\",\n  \"status\": \"ACTIVE\",\n  \"description\": \"General purpose computer lab\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/resources",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "resources"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "let data = {};",
              "try {",
              "    data = pm.response.json();",
              "} catch (e) {}",
              "",
              "if (data && data.id) {",
              "    pm.collectionVariables.set(\"resourceId\", String(data.id));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get All Resources",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/resources",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "resources"
          ]
        }
      }
    },
    {
      "name": "Get Resource By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/resources/{{resourceId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "resources",
            "{{resourceId}}"
          ]
        }
      }
    },
    {
      "name": "Update Resource",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Lab A - Updated\",\n  \"type\": \"LAB\",\n  \"capacity\": 45,\n  \"location\": \"Building B - Floor 3\",\n  \"availableFrom\": \"09:00\",\n  \"availableTo\": \"19:00\",\n  \"status\": \"ACTIVE\",\n  \"description\": \"Updated lab details\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/resources/{{resourceId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "resources",
            "{{resourceId}}"
          ]
        }
      }
    },
    {
      "name": "Delete Resource",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/resources/{{resourceId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "resources",
            "{{resourceId}}"
          ]
        }
      }
    }
  ]
}
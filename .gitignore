# IntelliJ IDEA shared project files
.idea/*
!.idea/
!.idea/.gitignore
!.idea/compiler.xml
!.idea/encodings.xml
!.idea/jarRepositories.xml
!.idea/misc.xml
!.idea/vcs.xml
*.iml

# Local editor files
.vscode/
**/.vscode/

# Local tool bundles and generated dependencies
.tools/
**/.tools/
server/.ai/
client/node_modules/
**/node_modules/

# Build output
client/dist/
**/dist/
build/
**/build/
server/target/
target/

# Runtime uploads should stay local
uploads/**
!uploads/
!uploads/.gitkeep
server/uploads/**
!server/uploads/
!server/uploads/.gitkeep
**/uploads/**
!**/uploads/
!**/uploads/.gitkeep

# Local secrets
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
